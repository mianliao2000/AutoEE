# AutoEE Copilot LLM backend
#
# Copy this file to .env and set the key for the provider you want to use.
# Supported providers are the names in autoee_demo/model_backend/registry.py:
# openai, anthropic, gemini, minimax, deepseek, qwen, openrouter, ollama, custom_openai, mock.

AUTOEE_LLM_PROVIDER=openai
AUTOEE_LLM_MODEL=gpt-5.5
AUTOEE_LLM_BASE_URL=https://api.openai.com/v1

# OpenAI
OPENAI_API_KEY=

# Other official provider keys
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
MINIMAX_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=
OPENROUTER_API_KEY=
CUSTOM_OPENAI_API_KEY=

# Official provider examples:
#
# ChatGPT / OpenAI
# AUTOEE_LLM_PROVIDER=openai
# AUTOEE_LLM_MODEL=gpt-5.5
# AUTOEE_LLM_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=
#
# Claude / Anthropic
# AUTOEE_LLM_PROVIDER=anthropic
# AUTOEE_LLM_MODEL=claude-sonnet-4-5
# AUTOEE_LLM_BASE_URL=https://api.anthropic.com/v1
# ANTHROPIC_API_KEY=
#
# Gemini / Google
# AUTOEE_LLM_PROVIDER=gemini
# AUTOEE_LLM_MODEL=gemini-2.5-pro
# AUTOEE_LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# GEMINI_API_KEY=
#
# DeepSeek
# AUTOEE_LLM_PROVIDER=deepseek
# AUTOEE_LLM_MODEL=deepseek-chat
# AUTOEE_LLM_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_API_KEY=
#
# Qwen / Alibaba DashScope OpenAI-compatible mode
# AUTOEE_LLM_PROVIDER=qwen
# AUTOEE_LLM_MODEL=qwen-max
# AUTOEE_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# QWEN_API_KEY=
#
# OpenRouter future-routing example:
# Use a different AUTOEE_LLM_MODEL while keeping AUTOEE_LLM_PROVIDER=openrouter.
# AUTOEE_LLM_PROVIDER=openrouter
# AUTOEE_LLM_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_API_KEY=
# AUTOEE_LLM_MODEL=openai/gpt-5.5
# AUTOEE_OPENROUTER_MODEL_CHATGPT=openai/gpt-5.5
# AUTOEE_OPENROUTER_MODEL_GEMINI=google/gemini-2.5-pro
# AUTOEE_OPENROUTER_MODEL_CLAUDE=anthropic/claude-sonnet-4.5
# AUTOEE_OPENROUTER_MODEL_DEEPSEEK=deepseek/deepseek-chat
# AUTOEE_OPENROUTER_MODEL_QWEN=qwen/qwen-max

# MiniMax OpenAI-compatible example:
# AUTOEE_LLM_PROVIDER=minimax
# AUTOEE_LLM_MODEL=MiniMax-M2.7
# AUTOEE_LLM_BASE_URL=https://api.minimax.io/v1
# MINIMAX_API_KEY=

# Local OpenAI-compatible servers can use:
# AUTOEE_LLM_PROVIDER=custom_openai
# AUTOEE_LLM_MODEL=your-model
# AUTOEE_LLM_BASE_URL=http://localhost:8000/v1
# CUSTOM_OPENAI_API_KEY=

# Local Ollama can use:
# AUTOEE_LLM_PROVIDER=ollama
# AUTOEE_LLM_MODEL=llama3.1
# AUTOEE_LLM_BASE_URL=http://localhost:11434
